rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Products Rules: Anyone can read, anyone can create (for seeding), only authenticated admin/seller can update/delete
    match /products/{productId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAuthenticated();
    }

    // Reviews Rules: Anyone can read and create, only authenticated admin/seller can delete or edit
    match /reviews/{reviewId} {
      allow read, create: if true;
      allow delete, update: if isAuthenticated();
    }

    // Instagram Posts Rules: Anyone can read, anyone can create (for seeding), only authenticated admin/seller can update/delete
    match /instagram_posts/{postId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAuthenticated();
    }

    // Settings Rules: Anyone can read, anyone can create (for seeding), only authenticated admin/seller can update/delete
    match /settings/{docId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAuthenticated();
    }

    // Coupons Rules: Anyone can read, anyone can create (for seeding), only authenticated admin/seller can update/delete
    match /coupons/{couponCode} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAuthenticated();
    }

    // Customers Rules: Anyone can create/write, only authenticated admin/seller can read/list or update/delete
    match /customers/{customerPhone} {
      allow create, update: if true;
      allow read, delete: if isAuthenticated();
    }

    // Orders Rules: Anyone can write (create order); anyone can read single if they match the order id (tracking), only authenticated admin/seller can list or update
    match /orders/{orderId} {
      allow create: if true;
      allow get: if true;
      allow list, update, delete: if isAuthenticated();
    }
  }
}
